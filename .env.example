# ListPilot environment variables — copy to .env.local and fill in.

# --- LLM (server-side only — NEVER expose to the client) ---
# Anthropic API key. Used by the /api/generate and /api/regenerate routes.
# Get one at https://console.anthropic.com/
LLM_API_KEY=

# --- Checkout links shown in the paywall (A/B price test) ---
# Option A — primary CTA: "Unlock unlimited — £39 one-time"
CHECKOUT_URL_ONCE=https://example.com/checkout/one-time
# Option B — secondary CTA: "Or subscribe — £19/month"
CHECKOUT_URL_SUB=https://example.com/checkout/subscription

# --- Hidden /admin analytics dashboard ---
# Visit /admin?secret=YOUR_SECRET. Blank page if the secret is wrong/missing.
ADMIN_SECRET=change-me

# --- Licence token signing (HMAC) ---
# Any long random string. Used to sign unlock tokens returned by /api/validate-licence.
LICENCE_SECRET=change-me-to-a-long-random-string

# --- v2 TODO: real Polar licence validation ---
# POLAR_API_KEY=
